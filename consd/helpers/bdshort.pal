/SHORT VERSION OF BDTIME FOR HAND TOGGLE IN
	*200
START,	DCA BDTIME	/INITIALIZE TO ZERO
	TLS		/SEND A NUL
	TSF		/DONT TIME THE FIRST ONE
	JMP .-1
	TLS		/SEND A NUL
BDLP,	TSF		/IS THE FLAG SET?
	JMP NOTSET	/NOT YET BUT SOON

	TAD BDTIME	/GET VALUE IN THE AC
	CMA IAC		/GET TWO's COMP
	HLT		/AND HALT

NOTSET,	ISZ BDTIME	/BUMP TIMER VALUE
	JMP BDLP	/LOOP IF NO OVERFLOW
	HLT		/SHOULDNT EVER GET HERE

BDTIME,	.-.

	$
