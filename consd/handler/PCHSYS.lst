  220 07727* 7006          RTL
  221 07730* 3352          DCA TEMP        /SAVE UPPER 8 BITS
  222 07731* 6031          KSF             /WAIT FOR LOWER 4 BITS
  223 07732* 5331          JMP .-1
  224 07733* 6036          KRB             /READ IN THE LOWER 4 BITS
  225 07734* 1352          TAD TEMP        /COMBINE
  226 07735* 5722          JMP I GET12     /RETURN
