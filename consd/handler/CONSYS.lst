   88 07600* 0000          ZBLOCK 7        /SKIP OVER THE OS/8 RESTART CODE
      07601* 0000
      07602* 0000
      07603* 0000
      07604* 0000
      07605* 0000
      07606* 0000
   89              
   90 07607* 0001  SYS,    VERS            /RESORC DISPLAYS THIS AS THE VERSION NUMBER
   91 07610* 4243          JMS SETUP       /NEVER RETURNS.  TELLS THE SERVER THE ENTRY POINT
   92              / THE ABOVE JMS SETUP WILL NEVER RETURN
   93              
   94              / SEND AN 8 BIT VALUE TO THE SERVER
   95 07611* 0000  SEND8,  .-.
   96 07612* 6041          TSF             /WAIT FOR LAST ONE TO COMPLETE
   97 07613* 5212          JMP .-1
   98 07614* 6046          TLS             /SEND THE CHARACTER
   99 07615* 5611          JMP I SEND8     /RETURN
  100              
  101              / SEND A 12 BIT VALUE TO THE SERVER
  102 07616* 0000  SEND12, .-.
  103 07617* 4211          JMS SEND8       /SEND THE LOWER 8 BITS
  104 07620* 7112          CLL RTR         /MOVE UPPER 4 BITS DOWN
  105 07621* 7012          RTR
  106 07622* 4211          JMS SEND8       /SEND THE UPPER 4 BITS
  107 07623* 7300          CLA CLL         /GET BACK TO KNOWN STATE
  108 07624* 5616          JMP I SEND12    /RETURN
  109              
  110              / GET A 12 BIT VALUE FROM THE SERVER
  111 07625* 0000  GET12,  .-.
  112 07626* 6031          KSF             /WAIT FOR A CHARACTER
  113 07627* 5226          JMP .-1
  114 07630* 6036          KRB             /READ IN THE CHARACTER
  115 07631* 7106          CLL RTL         /SHIFT LEFT 4 BITS
  116 07632* 7006          RTL
  117 07633* 3352          DCA TEMP        /SAVE UPPER 8 BITS
  118 07634* 6031          KSF             /WAIT FOR LOWER 4 BITS
  119 07635* 5234          JMP .-1



      / SERIAL DISK OVER THE CONSOLE PORT (SYS)                           Page 4


  120 07636* 6036          KRB             /READ IN THE LOWER 4 BITS
  121 07637* 1352          TAD TEMP        /COMBINE
  122 07640* 5625          JMP I GET12     /RETURN
  123              
  124              / THE 2ND ENTRY POINT SHOULD BE AT OFFSET 41.  ENFORCE SOMEHOW?
  125 07641* 0000  CSD1,   .-.             /2ND DEVICE ENTRY POINT
  126 07642* 4243          JMS SETUP       /NEVER RETURNS.  TELLS THE SERVER THE ENTRY POINT
  127              
  128 07643* 0000  SETUP,  .-.             /WE PASS THIS TO THE SERVER AND IT FIGURES IT ALL OUT
  129 07644* 7340          CLA CMA CLL     /GET AC AND LINK TO A KNOWN STATE
  130                                      /-1 IN THIS CASE TO INIT TSFSET
  131              
  132              /SD SHARES THE CONSOLE PORT.  THE CALLER COULD HAVE JUST SENT A CHAR SO
  133              / WE WAIT UP TO A CHAR TIME OR UNTIL THE FLAG IS SET.
  134 07645* 3342          DCA TSFSET      /INITIALIZE THE TSFSET FLAG TO INDICATE SET
  135 07646* 1256          TAD BDTIME      /WE NEED TO WAIT A CHARACTER TIME
  136 07647* 3352          DCA TEMP        /INITIALIZE THE TIMER COUNTER
  137 07650* 6041  BDLP,   TSF             /GET STATE OF TRANSMIT FLAG
  138 07651* 5253          JMP NOTSET      /WE WAIT FOR ONE
  139 07652* 5257          JMP WAKEUP      /WE GOT NO TSF FLAG.  SEND SERVER WAKEUP
  140              
  141 07653* 2352  NOTSET, ISZ TEMP        /HAVE WE WAITED A CHARACTER TIME?
  142 07654* 5250          JMP BDLP        /NOT YET
  143 07655* 2342          ISZ TSFSET      /MARK TSF FLAG AS NOT SET.  THIS ISZ WILL ALWAYS SKIP.
  144 07656* 7530  BDTIME, 7530            /TIMER CONSTANT.  SEE NOTES NEAR END.
  145              
  146              /WE NEED TO WAKEUP THE SERVER.  WE SEND IT THE WAKEUP CODE OF 02X WHERE
  147              /THE X IS REPLACED BY THE CALLERS DATA FIELD.
  148              
  149 07657* 6214  WAKEUP, RDF             /GET THE CALLERS DATA FIELD IN 6-8
  150 07660* 7012          RTR             /SHIFT RIGHT 3 BITS
  151 07661* 7010          RAR
  152 07662* 1327          TAD WKUP        /ADD IN THE WAKEUP CODE
  153 07663* 6046          TLS             /SEND THE WAKEUP COMMAND TO THE SERVER
  154              
  155              / NOW SEND THE ADDRESS OF THE ENTRY POINT USED
  156 07664* 7200          CLA             /OR HAVE THE SERVER SUBTRACT THE WAKEUP CODE FROM THIS
  157 07665* 1243          TAD SETUP       /GET POINTER TO ENTRY POINT
  158 07666* 4216          JMS SEND12      / AND SEND IT
  159              
  160              
  161              /AT THIS POINT THE SERVER IS IN DISK MODE AND WON'T SEND ANYMORE
  162              /CHARACTERS FROM THE KEYBOARD UNTIL THE REQUEST IS COMPLETED.
  163              
  164              /NOW HANDLE THE KEYBOARD
  165              / WE HAVE TO REMEMBER IF THE FLAG WAS SET ON ENTRY.  THE SERVER MUST
  166              / RESEND THE LAST KEYSTROKE AGAIN ALWAYS.
  167 07667* 7240          CLA CMA         /A -1 MEANS THE FLAG WAS SET
  168 07670* 6031          KSF             /IS THE FLAG SET?
  169 07671* 7001          IAC             /NO, A 0 MEANS THE FLAG WAS NOT SET



      / SERIAL DISK OVER THE CONSOLE PORT (SYS)                           Page 5


  170 07672* 3343          DCA KSFSET      /REMEMBER THIS
  171 07673* 6036          KRB             /READ WHATEVER IS IN THE BUFFER AND CLEAR THE FLAG
  172 07674* 4211          JMS SEND8       /AND SEND IT TO THE SERVER
  173              
  174              /NOW WE GO INTO COMMAND MODE AND DO WHAT THE SERVER TELLS US.
  175              
  176 07675* 4225  CMDLP,  JMS GET12       /READ THE ADDRESS
  177 07676* 3350          DCA CA          /SAVE THE CURRENT ADDRESS
  178 07677* 4225          JMS GET12       /READ THE WORD COUNT
  179 07700* 3351          DCA WC
  180 07701* 4225          JMS GET12       /READ THE COMMAND
  181 07702* 7500          SMA             /TEST FOR JMP COMMAND
  182 07703* 5316          JMP RDORWR      /IT IS A READ OR A WRITE COMMAND
  183              /WE HAVE A JMP COMMAND.
  184 07704* 3313          DCA FARJMP      /THIS IS A CDF CIF TO THE CALLERS RETURN FIELD
  185              / FIX UP THE TSF FLAG IF NECESSARY
  186 07705* 2342          ISZ TSFSET      /SKIP IF TSF FLAG WAS SET ON ENTRY
  187 07706* 6042          TCF             /ELSE CLEAR IT
  188              
  189              /HANDLE KSF AND CHARACTER IN INPUT BUFFER.  SERVER ALWAYS
  190              /RESENDS THE CHARACTER.
  191 07707* 6031          KSF             /WAIT FOR SERVER TO SEND THE CHARACTER
  192 07710* 5307          JMP .-1
  193 07711* 2343          ISZ KSFSET      /SKIP IF THE FLAG NEEDS TO BE LEFT SET
  194 07712* 6032          KCC             /ELSE CLEAR THE FLAG
  195              
  196 07713* 7402  FARJMP, HLT             /OVERWRITTEN BY A CDF CIF TO THE DESTINATION FLD
  197 07714* 1351          TAD WC          /THIS IS VALUE LOADED IN THE AC FOR THE RETURN
  198 07715* 5750          JMP I CA        /AND PERFORM THE FAR JMP
  199              
  200 07716* 7006  RDORWR, RTL             /LINK CLEAR IF READ, SET IF WRITE.
  201 07717* 7001          IAC             /NOW THIS IS A CDF INSTRUCTION.
  202 07720* 3321          DCA .+1         /AND EXECUTE NOW
  203 07721* 7402          HLT             /THIS BECOMES A CDF TO THE TRANSFER FIELD
  204 07722* 7430          SZL             /IS THIS A MEMORY WRITE
  205 07723* 5333          JMP RDMEM       /NO IT IS A MEMORY READ
  206              
  207 07724* 4225  WRMEM,  JMS GET12       /GET READ BYTE FROM SERVER
  208 07725* 3750          DCA I CA        /STORE IN USERS BUFFER
  209 07726* 2350          ISZ CA          /POINT AT NEXT
  210 07727* 0020  WKUP,   020             /EXECUTES AS A HARMLESS AND 020
  211 07730* 2351          ISZ WC          /ARE WE DONE YET?
  212 07731* 5324          JMP WRMEM       /NOT YET
  213              
  214 07732* 5275          JMP CMDLP       /GO GET NEXT COMMAND
  215              
  216 07733* 1750  RDMEM,  TAD I CA        /GET WORD TO BE WRITTEN
  217 07734* 2350          ISZ CA          /POINT AT NEXT
  218 07735* 7000          NOP             /IN CASE WE TRANSFER 7777
  219 07736* 4216          JMS SEND12      /SEND TO SERVER



